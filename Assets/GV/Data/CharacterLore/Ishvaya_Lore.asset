  m_Script: {fileID: 11500000, guid: a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6, type: 3}
  m_Name: Ishvaya_Lore
  m_EditorClassIdentifier: Assembly-CSharp::GV.UI.CharacterLoreData
  characterName: Ishvaya
  tagline: The vaults of Ratna Shila do not open for thieves.
  rarity: Rare
  role: Precision / Control
  regionLabel: Kingdom
  regionName: Ratna Shila
  factionLabel: Faction
  factionName: Yakshas
  powerClass: Celestial Astra Powers
  terrainMastery: Multi Terrain Mastery
  tharaResonance: Advance Thara Resonance
  backstory: "Sworn guardian of Ratna Shila - the jeweled fortress-kingdom of
    the Yakshas, keepers of sacred treasures hidden since the age of the Vimana builders.
    Ishvaya was raised in the Yaksha warrior tradition: measure twice, strike once,
    waste nothing. Her Celestial Astra may not match the raw power of Supreme-class
    weapons, but her Advance Thara Resonance means she can sustain combat far longer
    than most, wearing opponents down with patient precision. She never wanted the
    Garuda Trials. She was forced in when Vyanika's Garudaja raiders began striking
    Ratna Shila's outer vaults, and when Nysera - an Atom Rider intelligence
    broker from Inkara - sold Ratna Shila's defensive layouts to the highest
    bidder."
  strengths: "Unmatched precision at range; every shot is calculated\nAdvance Thara
    Resonance gives her deep energy reserves for sustained fights\nMulti Terrain Mastery
    makes her effective across varied battlefields"
  weaknesses: "Rigid Yaksha honor codes make her predictable to those who study her\n
    Celestial Astra lacks the raw burst of Supreme-class weapons\nClose-range chaos
    exposes her reliance on spacing and control"
  rivals: "Vyanika - Garudaja raider hitting her kingdom's vaults\nNysera
    - INTARi data-thief who sold Ratna Shila's secrets"
