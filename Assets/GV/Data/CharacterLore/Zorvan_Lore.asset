  m_Script: {fileID: 11500000, guid: a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6, type: 3}
  m_Name: Zorvan_Lore
  m_EditorClassIdentifier: Assembly-CSharp::GV.UI.CharacterLoreData
  characterName: Zorvan
  tagline: I drew a line. I held it.
  rarity: Rare
  role: Missile Hunter
  regionLabel: Country
  regionName: Aurkana
  factionLabel: Culture
  factionName: NEO-TERRANs
  powerClass: Antimatter Class Nuclear P
  terrainMastery: Dual Terrain Mastery
  tharaResonance: Normal Thara Resonance
  backstory: "Zorvan served as a missile systems officer in Aurkana\u2019s NEO-TERRAn
    military \u2014 the most technologically advanced armed force among the Earth
    Countries. He was assigned as a liaison to Roudra\u2019s Asura liberation campaign,
    part of Aurkana\u2019s covert support for Daitya Giri\u2019s rebellion. He believed
    in the cause \u2014 until Roudra ordered a strike on a civilian supply outpost.
    Zorvan refused the order. Roudra branded him a deserter. Aurkana disavowed him
    to avoid political fallout. Now he operates as a freelance missile specialist,
    selling his Antimatter-class lock-on expertise to whoever pays. One unbreakable
    rule: no civilian targets, ever."
  strengths: "Lock-on specialist; Antimatter-class missile systems are near-impossible
    to evade once acquired\nPatient hunter who fights from extreme range with military
    discipline\nDual Terrain Mastery from NEO-TERRAn training \u2014 effective in
    any arena"
  weaknesses: "Projectile weapons are baseline; depends entirely on missile lock-on
    windows\nDisavowed by Aurkana \u2014 no resupply network, no backup, no safe harbor\n
    Deep guilt over the Forge Wars; freezes when missions echo past atrocities"
  rivals: "Roudra \u2014 Branded him a traitor\nKaevik \u2014 Rival in the arms trade\n
    Virexa \u2014 Stole a contract he desperately needed"
