  m_Script: {fileID: 11500000, guid: a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6, type: 3}
  m_Name: Nysera_Lore
  m_EditorClassIdentifier: Assembly-CSharp::GV.UI.CharacterLoreData
  characterName: Nysera
  tagline: "You won't see me. You'll see the flash."
  rarity: Common
  role: Long-Range
  regionLabel: Country
  regionName: Inkara
  factionLabel: Culture
  factionName: INTARIs
  powerClass: Fusion Class Nuclear P
  terrainMastery: Multi Terrain Mastery
  tharaResonance: Advance Thara Resonance
  backstory: "Raised in Inkara's INTARi border settlements - a region caught
    between the old Kingdoms and the new Countries, where information is worth more
    than weapons. Nysera learned to survive by stealing data and selling it before
    anyone realized it was gone. She sold Ratna Shila's Yaksha defensive positions
    to rival kingdoms. She infiltrated Kaevik's QiNEXi weapons lab and walked
    out with Antimatter-class schematics. Her cybernetic eye - a salvaged targeting
    module reverse-engineered from ancient Vimana tech - lets her lock targets
    at distances others can barely detect. She partnered with Virexa once. A job in
    Elgorn Fall went wrong - Nysera took the data and left Virexa behind."
  strengths: "Extreme engagement range; Fusion-class systems tuned for distance strikes\n
    Advance Thara Resonance - deep energy reserves for sustained long-range
    pressure\nInformation warfare; she maps enemy weaknesses before the fight starts"
  weaknesses: "Fragile in close quarters; if someone closes the gap, she's finished\n
    Cybernetic implants cause chronic pain and need constant maintenance\nNo genuine
    loyalties; allies are temporary, which means support is too"
  rivals: "Kaevik - Stole his designs\nIshvaya - Sold Ratna Shila's
    secrets\nVirexa - Former partner; bitter separation"
